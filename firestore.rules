rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation definitions
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'updatedAt']) &&
             data.email is string && data.email.size() <= 255 &&
             data.createdAt is number && data.updatedAt is number &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100));
    }

    function isValidHighlight(data) {
      return data.keys().hasAll(['userId', 'docId', 'text', 'color', 'createdAt', 'updatedAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.docId is string && data.docId.size() <= 128 &&
             data.text is string && data.text.size() <= 5000 &&
             data.color is string && data.color.size() <= 50 &&
             data.createdAt is number && data.updatedAt is number &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000));
    }

    function isValidWorkspace(data) {
      return data.keys().hasAll(['userId', 'name', 'activeId', 'createdAt', 'updatedAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.activeId is string && data.activeId.size() <= 128 &&
             data.createdAt is number && data.updatedAt is number &&
             (!('parallelId' in data) || (data.parallelId is string && data.parallelId.size() <= 128));
    }

    // /users/{userId}
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
      allow list: if false; // Users shouldn't list all other users
      
      allow create: if isSignedIn() && isVerified() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming()) &&
                    incoming().createdAt == request.time.toMillis() &&
                    incoming().updatedAt == request.time.toMillis() &&
                    incoming().keys().size() <= 4;
                    
      allow update: if isSignedIn() && isVerified() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time.toMillis() &&
                    incoming().keys().size() <= 4 &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt'])
                    );
    }

    // /highlights/{highlightId}
    match /highlights/{highlightId} {
      allow get: if isSignedIn() && isValidId(highlightId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Only read their own

      allow create: if isSignedIn() && isVerified() && isValidId(highlightId) &&
                    isValidHighlight(incoming()) &&
                    incoming().createdAt == request.time.toMillis() &&
                    incoming().updatedAt == request.time.toMillis() &&
                    incoming().keys().size() <= 7;
                    
      allow update: if isSignedIn() && isVerified() && isValidId(highlightId) && existing().userId == request.auth.uid &&
                    isValidHighlight(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().docId == existing().docId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time.toMillis() &&
                    incoming().keys().size() <= 7 &&
                    (
                       incoming().diff(existing()).affectedKeys().hasOnly(['color', 'notes', 'updatedAt'])
                    );

      allow delete: if isSignedIn() && isVerified() && isValidId(highlightId) && existing().userId == request.auth.uid;
    }

    // /workspaces/{workspaceId}
    match /workspaces/{workspaceId} {
      allow get: if isSignedIn() && isValidId(workspaceId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Only read their own

      allow create: if isSignedIn() && isVerified() && isValidId(workspaceId) &&
                    isValidWorkspace(incoming()) &&
                    incoming().createdAt == request.time.toMillis() &&
                    incoming().updatedAt == request.time.toMillis() &&
                    incoming().keys().size() <= 6;
                    
      allow update: if isSignedIn() && isVerified() && isValidId(workspaceId) && existing().userId == request.auth.uid &&
                    isValidWorkspace(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time.toMillis() &&
                    incoming().keys().size() <= 6 &&
                    (
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'activeId', 'parallelId', 'updatedAt'])
                    );

      allow delete: if isSignedIn() && isVerified() && isValidId(workspaceId) && existing().userId == request.auth.uid;
    }
  }
}
